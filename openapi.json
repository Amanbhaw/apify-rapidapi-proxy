{
  "openapi": "3.0.0",
  "info": {
    "title": "Global Scraping API Suite — 13 Endpoints",
    "description": "Complete scraping toolkit: YouTube transcripts, B2B lead enrichment, Google Trends & Maps, Instagram profiles, Bluesky intelligence, Etsy shops, plus India (Tenders/GST/MCA) & Global B2B (UK/France/Germany) company data. Perfect for marketers, sales teams, VCs, researchers, AI engineers.",
    "version": "2.0.0",
    "contact": {
      "name": "Aman Bhawsar",
      "url": "https://apify.com/inexhaustible_glass"
    }
  },
  "servers": [
    { "url": "https://apify-rapidapi-proxy.onrender.com", "description": "Production" }
  ],
  "paths": {
    "/youtube-transcript": {
      "post": {
        "summary": "YouTube Transcript Extractor",
        "description": "Bulk extract transcripts from YouTube videos. 100+ languages.",
        "tags": ["Content"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["urls"],
                "properties": {
                  "urls": { "type": "array", "items": { "type": "string" }, "example": ["https://www.youtube.com/watch?v=dQw4w9WgXcQ"] },
                  "language": { "type": "string", "example": "en" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Transcripts" } }
      }
    },
    "/lead-enrichment": {
      "post": {
        "summary": "B2B Lead Enrichment",
        "description": "Enrich company URLs with emails, phones, tech stack, WHOIS, SSL, lead scores.",
        "tags": ["B2B Leads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["urls"],
                "properties": {
                  "urls": { "type": "array", "items": { "type": "string" }, "example": ["https://stripe.com"] },
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Enriched leads" } }
      }
    },
    "/google-trends": {
      "post": {
        "summary": "Google Trends Analyzer",
        "description": "Keyword trends, regions, related queries.",
        "tags": ["Content"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["keywords"],
                "properties": {
                  "keywords": { "type": "array", "items": { "type": "string" }, "example": ["AI", "ChatGPT"] },
                  "timeframe": { "type": "string", "example": "today 3-m" },
                  "geo": { "type": "string", "example": "US" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Trends data" } }
      }
    },
    "/google-maps-leads": {
      "post": {
        "summary": "Google Maps Business Leads",
        "description": "Extract business leads from Google Maps with emails, phones, addresses.",
        "tags": ["B2B Leads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["search_query"],
                "properties": {
                  "search_query": { "type": "string", "example": "Restaurants in Mumbai" },
                  "max_results": { "type": "integer", "example": 20 },
                  "extract_emails": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Business leads" } }
      }
    },
    "/instagram-profile": {
      "post": {
        "summary": "Instagram Profile Intelligence",
        "description": "Extract Instagram profile data, emails from bio, influencer tier, lead quality score.",
        "tags": ["Social Media"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["usernames"],
                "properties": {
                  "usernames": { "type": "array", "items": { "type": "string" }, "example": ["nike", "garyvee"] },
                  "concurrency": { "type": "integer", "example": 5 }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Instagram profiles with enrichment" } }
      }
    },
    "/bluesky-profile": {
      "post": {
        "summary": "Bluesky Intelligence (SkyScout)",
        "description": "Bluesky profiles, emails from bio, niche classification. Uses AT Protocol — no blocks.",
        "tags": ["Social Media"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "handles": { "type": "array", "items": { "type": "string" }, "example": ["bsky.app"] },
                  "searchQuery": { "type": "string", "example": "startup founder" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Bluesky profiles" } }
      }
    },
    "/etsy-shop": {
      "post": {
        "summary": "Etsy Shop Intelligence (ShopHound)",
        "description": "Deep Etsy shop research — sales, reviews, revenue estimate, seller tier.",
        "tags": ["E-commerce"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["shops"],
                "properties": {
                  "shops": { "type": "array", "items": { "type": "string" }, "example": ["LittleMushroomBakery"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Etsy shops" } }
      }
    },
    "/india-tenders": {
      "post": {
        "summary": "India Government Tenders (TenderHawk)",
        "description": "Latest Indian govt tenders from CPPP. For contractors, MSMEs, PSU suppliers.",
        "tags": ["India B2B"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "keywords": { "type": "array", "items": { "type": "string" }, "example": ["cpwd"] },
                  "categories": { "type": "array", "items": { "type": "string" }, "example": ["construction"] },
                  "minGrade": { "type": "string", "example": "D" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Tenders" } }
      }
    },
    "/india-gst": {
      "post": {
        "summary": "India GST Verification (GSTHawk)",
        "description": "Bulk verify GSTIN. Returns legal name, status, PAN, compliance grade.",
        "tags": ["India B2B"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["gstins", "appyflowKey"],
                "properties": {
                  "gstins": { "type": "array", "items": { "type": "string" }, "example": ["27AAAPG7885B1ZB"] },
                  "appyflowKey": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Verified GSTINs" } }
      }
    },
    "/india-company": {
      "post": {
        "summary": "India Company Master Data (MCAHawk)",
        "description": "MCA data for 25M+ Indian companies. Status, capital, directors.",
        "tags": ["India B2B"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cins": { "type": "array", "items": { "type": "string" }, "example": ["L65190MH2008PLC180169"] },
                  "searchQueries": { "type": "array", "items": { "type": "string" }, "example": ["reliance"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Indian companies" } }
      }
    },
    "/uk-company": {
      "post": {
        "summary": "UK Companies House Data (UKHawk)",
        "description": "5M+ UK companies. Status, SIC codes, directors.",
        "tags": ["Global B2B"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "companyNumbers": { "type": "array", "items": { "type": "string" }, "example": ["00445790"] },
                  "searchQueries": { "type": "array", "items": { "type": "string" }, "example": ["tesco"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "UK companies" } }
      }
    },
    "/france-company": {
      "post": {
        "summary": "France Company Data (FRHawk)",
        "description": "10M+ French companies. SIREN, SIRET, capital, industry.",
        "tags": ["Global B2B"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sirens": { "type": "array", "items": { "type": "string" }, "example": ["542051180"] },
                  "searchQueries": { "type": "array", "items": { "type": "string" }, "example": ["totalenergies"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "French companies" } }
      }
    },
    "/germany-company": {
      "post": {
        "summary": "Germany Handelsregister (DEHawk)",
        "description": "German companies via Northdata. Name, HRB, LEI, management.",
        "tags": ["Global B2B"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["queries"],
                "properties": {
                  "queries": { "type": "array", "items": { "type": "string" }, "example": ["Volkswagen+AG,+Wolfsburg/HRB+100484"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "German companies" } }
      }
    }
  }
}
